# Supabase Edge Function secrets — template.
#
# Copy this file to `supabase/.env` (which is gitignored) and fill in the
# values. Then push everything in one shot:
#
#   supabase secrets set --env-file supabase/.env --project-ref fhgevybapodhubkuylnw
#
# This sets the variables as Function Secrets in the Supabase project so the
# edge function (`make-server-1fdc8e05`) can read them via Deno.env.get(...).
# The values never reach the frontend bundle.

# REQUIRED — Google Places API key for the /google-reviews endpoint.
# Get one at: https://console.cloud.google.com/apis/credentials
# Restrict it to the Places API (New) for safety.
GOOGLE_PLACES_API_KEY=

# REQUIRED — Resend API key for the /contact endpoint.
# Get one at: https://resend.com/api-keys
RESEND_API_KEY=

# OPTIONAL — defaults to "Tolunay.u@outlook.de" inside the function.
# Override here if you want submissions to go somewhere else.
CONTACT_EMAIL_TO=

# OPTIONAL — defaults to "onboarding@resend.dev" inside the function.
# Switch to noreply@yourdomain.de once you've verified the domain in Resend
# (until then your emails will land in the spam folder for most recipients).
CONTACT_EMAIL_FROM=

# OPTIONAL — comma-separated list of origins allowed to call the function.
# Defaults to "*" (fully open). Pin to your production domain(s) once you
# have one, e.g. "https://puron.agency,https://www.puron.agency".
ALLOWED_ORIGINS=
